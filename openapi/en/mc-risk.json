                              "nextSettlementTime": {
                                "type": "integer",
                                "format": "int64",
                                "example": 1697331200000
                              },
                              "timestamp": {
                                "type": "integer",
                                "format": "int64",
                                "example": 1697331200000
                              },
                              "settlementCycle": {
                                "type": "integer",
                                "format": "int64",
                                "example": 3600
                              }
                            },
                            "example": null
