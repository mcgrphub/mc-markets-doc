                                "type": "number",
                                "example": 0.0001
                              },
                              "settlementPriceStr": {
                                "type": "string",
                                "example": "3964.2"
                              },
                              "settlementPriceDisplay": {
                                "type": "string",
                                "example": "3964.2"
                              },
                              "settlementPriceScale": {
                                "type": "integer",
                                "format": "int32",
                                "example": 2
                              },
                              "longInterestRate": {
                                "type": "number",
                                "example": 0.0001
                              },
                              "longInterestRateStr": {
                                "type": "string",
                                "example": "1.0E-4"
                              },
                              "shortInterestRate": {
                                "type": "number",
                                "example": 0.0001
                              },
