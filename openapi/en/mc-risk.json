  "paths": {
    "/openapi/v1/mc-risk/trade/symbol/list": {
      "get": {
        "tags": [
          "Trading"
        ],
        "summary": "Trading Symbol List",
        "description": "Query the trading symbol list based on the current user's UID\nRequired Permission: READ",
        "operationId": "list",
        "parameters": [
          {
            "name": "req",
            "in": "query",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "size": {
                  "type": "integer",
                  "format": "int64",
                  "example": 10
                },
                "current": {
                  "type": "integer",
                  "format": "int64",
                  "example": 1
                },
                "orderBy": {
                  "type": "string",
                  "description": "Supports multi-field sorting, separated by commas",
                  "example": "id,createTime"
                },
                "orderDirection": {
                  "type": "string",
                  "description": "ASC for ascending / DESC for descending; separate multiple fields with commas",
                  "example": "DESC,ASC",
                  "enum": [
                    "ASC",
                    "DESC"
                  ]
                },
                "group": {
                  "type": "string"
                }
              },
              "example": null
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer",
                      "format": "int32"
                    },
                    "message": {
                      "type": "string"
                    },
                    "code": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "records": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "symbol": {
                                "type": "string",
                                "description": "Product Name"
                              },
                              "group": {
                                "type": "string",
                                "description": "Product Group"
                              },
                              "flags": {
                                "type": "string",
                                "description": "Symbol tags: MORTGAGE: Collateral, TRADE: Trading Symbol, SPOT: Spot",
                                "enum": [
                                  "MORTGAGE",
                                  "TRADE",
                                  "SPOT",
                                  "TRADE",
                                  "MORTGAGE",
                                  "SPOT"
                                ]
                              }
                            },
                            "example": null
                          }
                        },
                        "total": {
                          "type": "integer",
                          "format": "int64"
                        },
                        "size": {
                          "type": "integer",
                          "format": "int64"
                        },
                        "current": {
                          "type": "integer",
                          "format": "int64"
                        },
                        "pages": {
                          "type": "integer",
                          "format": "int64"
                        },
                        "hasPrevious": {
                          "type": "boolean"
                        },
                        "hasNext": {
                          "type": "boolean"
                        }
                      },
                      "example": null
                    },
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "example": null
                }
              }
            }
          }
        }
      }
    },
