                      "type": "object"
                    },
                    "localizedMessage": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer",
                          "description": "Total number of symbols in current category",
                          "format": "int64"
                        },
                        "page": {
                          "type": "integer",
                          "description": "Current page number",
                          "format": "int32"
                        },
                        "pageSize": {
                          "type": "integer",
                          "description": "Number of records per page",
                          "format": "int32"
                        },
                        "snapshotVersion": {
                          "type": "integer",
                          "description": "Ranking snapshot version number",
                          "format": "int64"
                        },
                        "items": {
                          "type": "array",
                          "description": "Ranking entries on current page",
                          "items": {
                            "type": "object",
                            "properties": {
                              "rank": {
                                "type": "integer",
                                "description": "Global rank",
                                "format": "int32"
                              },
                              "symbol": {
                                "type": "string",
                                "description": "Symbol Code"
                              },
                              "bid": {
                                "type": "string",
                                "description": "Bid Price"
                              },
                              "change24hAbs": {
                                "type": "string",
                                "description": "24h change amount"
                              },
                              "change24hPct": {
                                "type": "string",
                                "description": "24h change percentage (decimal form, e.g., -0.0146 means -1.46%)"
                              },
                              "isHot": {
                                "type": "boolean",
                                "description": "Whether hot"
                              },
                              "pricingDegree": {
                                "type": "integer",
                                "description": "Price Decimal Places",
                                "format": "int32"
                              }
                            },
                            "description": "Symbol market ranking entry",
                            "example": null
