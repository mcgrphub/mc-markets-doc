    "/openapi/v1/mc-aggregator/market-data/symbol-ranking": {
      "get": {
        "tags": [
          "Market Data API"
        ],
        "summary": "Symbol Market Ranking",
        "description": "Paginated query of symbol market rankings by category and sort dimension\nRequired Permission: READ",
        "operationId": "symbolRanking",
        "parameters": [
          {
            "name": "req",
            "in": "query",
            "required": true,
            "schema": {
              "required": [
                "category"
              ],
              "type": "object",
              "properties": {
                "category": {
                  "type": "string",
                  "description": "Tab category: CONTRACT/SPOT/CRYPTO/TRADFI"
                },
                "subGroup": {
                  "type": "string",
                  "description": "Traditional finance secondary tab: ALL/FOREX/METALS/INDICES/ENERGY/STOCKS"
                },
                "hotOnly": {
                  "type": "boolean",
                  "description": "Whether to return only hot symbols (isHot=1 and status=1)"
                },
                "sortBy": {
                  "type": "string",
                  "description": "Sort field: symbol/bid/change24hPct"
                },
                "sortOrder": {
                  "type": "string",
                  "description": "Sort direction: asc/desc"
                },
                "page": {
                  "type": "integer",
                  "description": "Page number, starting from 1",
                  "format": "int32"
                },
                "pageSize": {
                  "type": "integer",
                  "description": "Number of records per page",
                  "format": "int32"
                }
              },
              "description": "Symbol market ranking query request",
              "example": null
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer",
                      "format": "int32"
                    },
