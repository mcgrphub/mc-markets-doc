    "/openapi/v1/mc-aggregator/market-data/kline": {
      "get": {
        "tags": [
          "Market Data API"
        ],
        "summary": "Query K-line Data",
        "description": "Query K-line data by symbol, time interval, and time range\nRequired Permission: READ",
        "operationId": "klineList",
        "parameters": [
          {
            "name": "req",
            "in": "query",
            "required": true,
            "schema": {
              "required": [
                "endTime",
                "period",
                "symbol"
              ],
              "type": "object",
              "properties": {
                "symbol": {
                  "type": "string",
                  "description": "Symbol Code",
                  "example": "EURUSD"
                },
                "period": {
                  "type": "integer",
                  "description": "1min-1, 5min-5, 15min-15, 1hour-60, 4hour-240, 1day-1440, 1week-1440*7, 1month-1440*30",
                  "format": "int32"
                },
                "startTime": {
                  "type": "integer",
                  "description": "Start time, second-level timestamp",
                  "format": "int64",
                  "example": 1755792000
                },
                "endTime": {
                  "type": "integer",
                  "description": "End time, second-level timestamp",
                  "format": "int64",
                  "example": 1755878400
                },
                "limit": {
                  "type": "integer",
                  "description": "Maximum number of records per request, max allowed value is 500",
                  "format": "int32",
                  "example": 500
                }
              },
              "example": null
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer",
                      "format": "int32"
                    },
                    "message": {
                      "type": "string"
                    },
                    "code": {
                      "type": "string"
                    },
                    "codeKey": {
                      "type": "string",
                      "description": "Business error key (ExceptionTypeEnum name). Full list: /api-reference/error-codes."
                    },
                    "params": {
                      "type": "object"
                    },
                    "localizedMessage": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "pricingDegree": {
                          "type": "integer",
                          "description": "Price precision, used to convert values to floating point numbers",
                          "format": "int32"
                        },
                        "klineDataList": {
                          "type": "array",
                          "description": "K-line data list, in order: open price, close price, high price, low price, volume, second-level timestamp",
                          "items": {
                            "type": "string",
                            "description": "K-line data list, in order: open price, close price, high price, low price, volume, second-level timestamp"
                          }
                        },
                        "klineDisplayList": {
                          "type": "array",
                          "description": "K-line display field list, consistent with klineDataList order",
                          "items": {
                            "type": "object",
                            "properties": {
                              "openStr": {
                                "type": "string",
                                "description": "Open price raw plain string"
                              },
                              "openDisplay": {
                                "type": "string",
                                "description": "Open price display text"
                              },
                              "openScale": {
                                "type": "integer",
                                "description": "Open price display decimal places",
                                "format": "int32"
                              },
                              "closeStr": {
                                "type": "string",
                                "description": "Close price raw plain string"
                              },
                              "closeDisplay": {
                                "type": "string",
                                "description": "Close price display text"
                              },
                              "closeScale": {
                                "type": "integer",
                                "description": "Close price display decimal places",
                                "format": "int32"
                              },
                              "highStr": {
                                "type": "string",
                                "description": "High price raw plain string"
                              },
                              "highDisplay": {
                                "type": "string",
                                "description": "High price display text"
                              },
                              "highScale": {
                                "type": "integer",
                                "description": "High price display decimal places",
                                "format": "int32"
                              },
                              "lowStr": {
                                "type": "string",
                                "description": "Low price raw plain string"
                              },
                              "lowDisplay": {
                                "type": "string",
                                "description": "Low price display text"
                              },
                              "lowScale": {
                                "type": "integer",
                                "description": "Low price display decimal places",
                                "format": "int32"
                              },
                              "volumeStr": {
                                "type": "string",
                                "description": "Trading volume raw plain string"
                              },
                              "volumeDisplay": {
                                "type": "string",
                                "description": "Trading volume display text"
                              },
                              "volumeScale": {
                                "type": "integer",
                                "description": "Trading volume display decimal places",
                                "format": "int32"
                              },
                              "timestamp": {
                                "type": "integer",
                                "description": "Second-level timestamp",
                                "format": "int64"
                              }
                            },
                            "description": "Compact K-line display fields",
                            "example": null
                          }
                        }
                      },
                      "description": "K-line data query response",
                      "example": null
                    },
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "example": null
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer",
                      "format": "int32"
                    },
                    "message": {
                      "type": "string"
                    },
                    "code": {
                      "type": "string"
                    },
                    "codeKey": {
                      "type": "string",
                      "description": "Business error key (ExceptionTypeEnum name). Full list: /api-reference/error-codes."
                    },
                    "params": {
                      "type": "object"
                    },
                    "localizedMessage": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object"
                    },
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "example": null
                }
              }
            }
          }
        }
      }
