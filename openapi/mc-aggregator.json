          {
            "name": "req",
            "in": "query",
            "required": true,
            "schema": {
              "required": [
                "category"
              ],
              "type": "object",
              "properties": {
                "category": {
                  "type": "string",
                  "description": "Tab 分类：CONTRACT/SPOT/CRYPTO/TRADFI"
                },
                "subGroup": {
                  "type": "string",
                  "description": "传统金融二级 Tab：ALL/FOREX/METALS/INDICES/ENERGY/STOCKS"
