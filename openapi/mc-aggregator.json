                    },
                    "params": {
                      "type": "object"
                    },
                    "localizedMessage": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "pricingDegree": {
                          "type": "integer",
                          "description": "价格精度, 用于把数值转换浮点数",
                          "format": "int32"
                        },
                        "klineDataList": {
                          "type": "array",
                          "description": "K线数据列表, 依次代表：开盘价,收盘价,最高价,最低价,交易量,秒级时间戳",
