                              },
                              "openDisplay": {
                                "type": "string",
                                "description": "开盘价展示文本"
                              },
                              "openScale": {
                                "type": "integer",
                                "description": "开盘价展示小数位",
                                "format": "int32"
                              },
                              "closeStr": {
                                "type": "string",
                                "description": "收盘价原始 plain string"
                              },
                              "closeDisplay": {
                                "type": "string",
                                "description": "收盘价展示文本"
                              },
                              "closeScale": {
                                "type": "integer",
                                "description": "收盘价展示小数位",
                                "format": "int32"
                              },
                              "highStr": {
                                "type": "string",
                                "description": "最高价原始 plain string"
                              },
                              "highDisplay": {
                                "type": "string",
                                "description": "最高价展示文本"
                              },
                              "highScale": {
                                "type": "integer",
                                "description": "最高价展示小数位",
                                "format": "int32"
                              },
                              "lowStr": {
                                "type": "string",
                                "description": "最低价原始 plain string"
                              },
                              "lowDisplay": {
                                "type": "string",
                                "description": "最低价展示文本"
                              },
                              "lowScale": {
                                "type": "integer",
                                "description": "最低价展示小数位",
                                "format": "int32"
                              },
                              "volumeStr": {
                                "type": "string",
                                "description": "交易量原始 plain string"
                              },
                              "volumeDisplay": {
                                "type": "string",
                                "description": "交易量展示文本"
                              },
                              "volumeScale": {
                                "type": "integer",
                                "description": "交易量展示小数位",
                                "format": "int32"
                              },
                              "timestamp": {
                                "type": "integer",
                                "description": "秒级时间戳",
                                "format": "int64"
                              }
                            },
                            "description": "compact K线展示字段",
                            "example": null
                          }
                        }
                      },
                      "description": "K线数据查询响应",
                      "example": null
                    },
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "example": null
                }
              }
            }
          }
        }
      }
