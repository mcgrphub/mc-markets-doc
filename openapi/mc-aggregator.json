          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer",
                      "format": "int32"
                    },
                    "message": {
                      "type": "string"
                    },
                    "code": {
                      "type": "string"
                    },
                    "codeKey": {
                      "type": "string",
                      "description": "业务错误键（ExceptionTypeEnum 名称）。完整列表见 /zh/api-reference/error-codes。"
                    },
                    "params": {
                      "type": "object"
                    },
                    "localizedMessage": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer",
                          "description": "当前分类下品种总数",
                          "format": "int64"
                        },
                        "page": {
                          "type": "integer",
                          "description": "当前页码",
                          "format": "int32"
                        },
                        "pageSize": {
                          "type": "integer",
                          "description": "每页条数",
                          "format": "int32"
                        },
