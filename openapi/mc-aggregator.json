    "/openapi/v1/mc-aggregator/market-data/kline": {
      "get": {
        "tags": [
          "行情数据"
        ],
        "summary": "查询K线数据",
        "description": "根据币种、时间间隔、时间范围查询K线数据\n所需权限: READ",
        "operationId": "klineList",
        "parameters": [
          {
            "name": "req",
            "in": "query",
            "required": true,
            "schema": {
              "required": [
                "endTime",
                "period",
                "symbol"
              ],
              "type": "object",
              "properties": {
                "symbol": {
                  "type": "string",
                  "description": "交易品种代码",
                  "example": "EURUSD"
                },
                "period": {
                  "type": "integer",
                  "description": "1分钟-1, 5分钟-5, 15分钟-15, 1小时-60, 4小时-240, 1天-1440, 1周-1440*7, 1月-1440*30",
                  "format": "int32"
                },
                "startTime": {
                  "type": "integer",
                  "description": "开始时间, 秒级时间戳",
                  "format": "int64",
                  "example": 1755792000
                },
                "endTime": {
                  "type": "integer",
                  "description": "结束时间, 秒级时间戳",
                  "format": "int64",
                  "example": 1755878400
                },
                "limit": {
                  "type": "integer",
                  "description": "单次最大返回条数, 允许传入最大值500",
                  "format": "int32",
                  "example": 500
                }
              },
              "example": null
            }
          }
        ],
        "responses": {
          "400": {
            "description": "Bad Request",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer",
                      "format": "int32"
                    },
                    "message": {
                      "type": "string"
                    },
                    "code": {
                      "type": "string"
                    },
