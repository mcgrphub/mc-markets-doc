                          "type": "array",
                          "description": "当前页排行条目",
                          "items": {
                            "type": "object",
                            "properties": {
                              "rank": {
                                "type": "integer",
                                "description": "全局名次",
                                "format": "int32"
                              },
                              "symbol": {
                                "type": "string",
                                "description": "品种代码"
                              },
                              "bid": {
                                "type": "string",
                                "description": "买价"
                              },
                              "change24hAbs": {
                                "type": "string",
                                "description": "24h 涨跌额"
                              },
                              "change24hPct": {
                                "type": "string",
                                "description": "24h 涨跌幅（小数形式，如 -0.0146 表示 -1.46%）"
                              },
                              "isHot": {
                                "type": "boolean",
                                "description": "是否热门"
                              },
                              "pricingDegree": {
                                "type": "integer",
                                "description": "价格小数位",
                                "format": "int32"
                              }
                            },
                            "description": "币种行情排行条目",
                            "example": null
                          }
                        }
