                      "type": "string",
                      "description": "业务错误键（ExceptionTypeEnum 名称）。完整列表见 /zh/api-reference/error-codes。"
                    },
                    "params": {
                      "type": "object"
                    },
                    "localizedMessage": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object"
                    },
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "example": null
                }
              }
            }
          },
