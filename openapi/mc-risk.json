  "paths": {
    "/openapi/v1/mc-risk/trade/symbol/list": {
      "get": {
        "tags": [
          "交易"
        ],
        "summary": "交易品种列表",
        "description": "查询当前可用的交易品种列表\n所需权限: READ",
        "operationId": "list",
        "parameters": [
          {
            "name": "req",
            "in": "query",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "size": {
                  "type": "integer",
                  "description": "每页显示条数",
                  "format": "int64",
                  "example": 10
                },
                "current": {
                  "type": "integer",
                  "description": "当前页码",
                  "format": "int64",
                  "example": 1
                },
                "orderBy": {
                  "type": "string",
                  "description": "支持多字段排序，用逗号分隔",
                  "example": "id,createTime"
                },
                "orderDirection": {
                  "type": "string",
                  "description": "ASC升序/DESC降序，多字段时用逗号分隔",
                  "example": "DESC,ASC",
                  "enum": [
                    "ASC",
                    "DESC"
                  ]
                },
                "group": {
                  "type": "string",
                  "description": "产品分组（MT5 Path 最后一段，如 Forex）；省略或为空时返回所有已配置分组下的直接子品种"
                }
              },
              "description": "交易品种分页查询请求",
              "example": null
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer",
                      "format": "int32"
                    },
                    "message": {
                      "type": "string"
                    },
                    "code": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "records": {
                          "type": "array",
                          "description": "当前页记录列表",
                          "items": {
                            "type": "object",
                            "properties": {
                              "symbol": {
                                "type": "string",
                                "description": "产品名称"
                              },
                              "group": {
                                "type": "string",
                                "description": "产品分组"
                              },
                              "flags": {
                                "type": "string",
                                "description": "品种标签, MORTGAGE:抵押品，TRADE:交易品种,SPOT:现货",
                                "enum": [
                                  "MORTGAGE",
                                  "TRADE",
                                  "SPOT",
                                  "TRADE",
                                  "MORTGAGE",
                                  "SPOT"
                                ]
                              }
                            },
                            "description": "当前页记录列表",
                            "example": null
                          }
                        },
                        "total": {
                          "type": "integer",
                          "description": "总记录数",
                          "format": "int64"
                        },
                        "size": {
                          "type": "integer",
                          "description": "每页条数",
                          "format": "int64"
                        },
                        "current": {
                          "type": "integer",
                          "description": "当前页码",
                          "format": "int64"
                        },
                        "pages": {
                          "type": "integer",
                          "description": "总页数",
                          "format": "int64"
                        },
                        "hasPrevious": {
                          "type": "boolean",
                          "description": "是否有上一页"
                        },
                        "hasNext": {
                          "type": "boolean",
                          "description": "是否有下一页"
                        }
                      },
                      "example": null
                    },
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "example": null
                }
              }
            }
          }
        }
      }
    },
